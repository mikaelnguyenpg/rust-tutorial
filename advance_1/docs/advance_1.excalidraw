      "link": null,
      "locked": false,
      "text": "fn add_number(mut n: i32) -> i32 {\n    // mut: mutuable\n    n = n + 10;\n    n\n}\n\nfn main() {\n    let a = 5;\n    let b = add_number(a); // 15\n\n    println!(\"Value of a: {}\", a);\n    println!(\"Value of b: {}\", b);\n}\n",
      "fontSize": 15.658035714285727,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "fn add_number(mut n: i32) -> i32 {\n    // mut: mutuable\n    n = n + 10;\n    n\n}\n\nfn main() {\n    let a = 5;\n    let b = add_number(a); // 15\n\n    println!(\"Value of a: {}\", a);\n    println!(\"Value of b: {}\", b);\n}\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
