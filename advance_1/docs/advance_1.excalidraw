    {
      "id": "X3FOW9MR1JBDhl_cNTJrH",
      "type": "text",
      "x": 411.19898451762515,
      "y": 5467.796570559084,
      "width": 542.1609304327714,
      "height": 775,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1K",
      "roundness": null,
      "seed": 1396699982,
      "version": 448,
      "versionNonce": 924922194,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772633567823,
      "link": null,
      "locked": false,
      "text": "User\n{\n    id: 123,\n    name: \"User A\",\n    email: \"user-a@mail.com\"\n    ....\n}\n\n\n/api/{domain} -> api/user\n\n1. Create user\nPOST: /api/user \nBody: aplication/json\n\n2. Edit user\nPUT: /api/users/{id}\nBody: application/json\n\n3. Get user detail\nGET: /api/users/{id}\n\n4. Delete user\nDELETE: /api/users/{id}\n\n5. Get all users\nGET: /api/users\n\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User\n{\n    id: 123,\n    name: \"User A\",\n    email: \"user-a@mail.com\"\n    ....\n}\n\n\n/api/{domain} -> api/user\n\n1. Create user\nPOST: /api/user \nBody: aplication/json\n\n2. Edit user\nPUT: /api/users/{id}\nBody: application/json\n\n3. Get user detail\nGET: /api/users/{id}\n\n4. Delete user\nDELETE: /api/users/{id}\n\n5. Get all users\nGET: /api/users\n\n\n\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
